apiVersion: operator.dash0.com/v1alpha1
kind: Dash0SpamFilter
metadata:
  name: spam-filter-e2e-test
  labels:
    app.kubernetes.io/name: spam-filter-e2e-test
{{- if .Dash0ComEnabled }}
    dash0.com/enabled: {{ .Dash0ComEnabled | quote }}
{{- end }}
spec:
  contexts:
    - log
  filter:
    - key: "k8s.namespace.name"
      operator: "is"
      value: "kube-system"
