apiVersion: operator.dash0.com/v1alpha1
kind: Dash0SignalToMetrics
metadata:
  name: signal-to-metrics-e2e-test
  labels:
    app.kubernetes.io/name: signal-to-metrics-e2e-test
{{- if .Dash0ComEnabled }}
    dash0.com/enabled: {{ .Dash0ComEnabled | quote }}
{{- end }}
    dash0.com/dataset: default
    dash0.com/id: 14cdf74a-3b1c-48a3-ab6a-b97910853760
    dash0.com/source: userdefined
    dash0.com/version: "1"
spec:
  enabled: true
  display:
    name: E2E test signal-to-metrics rule
  match:
    signal: spans
    filters:
      - key: service.name
        operator: is
        value: checkout-service
  output:
    name: checkout.request.duration
    description: How long calls to our checkout API take
    interval: 60s
