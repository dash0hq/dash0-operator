        plural: dash0signaltometrics
        singular: dash0signaltometrics
      scope: Namespaced
      versions:
        - name: v1alpha1
          schema:
            openAPIV3Schema:
              description: |-
                Dash0SignalToMetrics is the Schema for the dash0signaltometrics API.
                It defines a single rule that derives a custom metric from spans or log records.
              properties:
                apiVersion:
                  description: |-
                    APIVersion defines the versioned schema of this representation of an object.
                    Servers should convert recognized schemas to the latest internal value, and
                    may reject unrecognized values.
                    More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#resources
                  type: string
                kind:
                  description: |-
                    Kind is a string value representing the REST resource this object represents.
                    Servers may infer this from the endpoint the client submits requests to.
                    Cannot be updated.
                    In CamelCase.
                    More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#types-kinds
                  type: string
                metadata:
                  type: object
                spec:
                  description: Dash0SignalToMetricsSpec defines the desired state of a SignalToMetrics rule.
                  properties:
                    display:
                      description: Display configuration for the rule (e.g. the human-readable name shown in the Dash0 UI).
                      properties:
                        name:
                          description: Human-readable name for this rule.
                          minLength: 1
                          type: string
                      required:
                        - name
                      type: object
                    enabled:
                      description: Whether this rule is active.
                      type: boolean
                    match:
                      description: Match selects which signals this rule applies to.
                      properties:
                        filters:
                          description: Filters that determine which spans / log records contribute to the output metric.
                          items:
                            description: Dash0SignalToMetricsAttributeFilter is a single filter against an attribute key.
                            properties:
                              key:
                                description: The attribute key to match against.
                                minLength: 1
                                type: string
                              operator:
                                description: The match operator.
                                enum:
                                  - is
                                  - is_not
                                  - is_set
                                  - is_not_set
                                  - is_one_of
                                  - is_not_one_of
                                  - gt
                                  - lt
                                  - gte
                                  - lte
                                  - matches
                                  - does_not_match
                                  - contains
                                  - does_not_contain
                                  - starts_with
                                  - does_not_start_with
                                  - ends_with
                                  - does_not_end_with
                                  - is_any
                                type: string
                              value:
                                description: Single value for operators that accept one value (is, is_not, contains, matches, ...).
                                type: string
                              values:
                                description: List of values for the is_one_of / is_not_one_of operators.
                                items:
                                  type: string
                                type: array
                            required:
                              - key
                              - operator
                            type: object
                          minItems: 1
                          type: array
                        signal:
                          description: The signal type this rule applies to. Spans produce exponential histograms; log records produce count metrics.
                          enum:
                            - spans
                            - logs
                          type: string
                      required:
                        - filters
                        - signal
                      type: object
                    output:
                      description: Output controls the metric that is produced for matching signals.
                      properties:
                        description:
                          description: Optional description used as metadata on the generated metric.
                          type: string
                        interval:
                          description: 'Interval at which a data point is emitted for matched signals. Backend bounds: 5s..10m.'
                          pattern: ^(\d+(ms|s|m|h|d|w|M|Q|y))+$
                          type: string
                        keepResourceAttributes:
                          description: Key matchers that select resource attributes to carry over to the output metric.
                          items:
                            description: |-
                              Dash0SignalToMetricsMatcher is a key-less variant of an attribute filter used for keepResourceAttributes /
                              keepSignalAttributes selection: it matches against attribute keys.
                            properties:
                              operator:
                                description: The match operator.
                                enum:
                                  - is
                                  - is_not
                                  - is_set
                                  - is_not_set
                                  - is_one_of
                                  - is_not_one_of
                                  - gt
                                  - lt
                                  - gte
                                  - lte
                                  - matches
                                  - does_not_match
                                  - contains
                                  - does_not_contain
                                  - starts_with
                                  - does_not_start_with
                                  - ends_with
                                  - does_not_end_with
                                  - is_any
                                type: string
                              value:
                                description: Single value for operators that accept one value.
                                type: string
                              values:
                                description: List of values for the is_one_of / is_not_one_of operators.
                                items:
                                  type: string
                                type: array
                            required:
                              - operator
                            type: object
                          type: array
                        keepSignalAttributes:
                          description: Key matchers that select span/log record attributes to carry over as metric dimensions.
                          items:
                            description: |-
                              Dash0SignalToMetricsMatcher is a key-less variant of an attribute filter used for keepResourceAttributes /
                              keepSignalAttributes selection: it matches against attribute keys.
                            properties:
                              operator:
                                description: The match operator.
                                enum:
                                  - is
                                  - is_not
                                  - is_set
                                  - is_not_set
                                  - is_one_of
                                  - is_not_one_of
                                  - gt
                                  - lt
                                  - gte
                                  - lte
                                  - matches
                                  - does_not_match
                                  - contains
                                  - does_not_contain
                                  - starts_with
                                  - does_not_start_with
                                  - ends_with
                                  - does_not_end_with
                                  - is_any
                                type: string
                              value:
                                description: Single value for operators that accept one value.
                                type: string
                              values:
                                description: List of values for the is_one_of / is_not_one_of operators.
                                items:
                                  type: string
                                type: array
                            required:
                              - operator
                            type: object
                          type: array
                        name:
                          description: The name of the resulting metric.
                          minLength: 1
                          type: string
                      required:
                        - interval
                        - name
                      type: object
                  required:
                    - display
                    - enabled
                    - match
                    - output
                  type: object
                status:
