should install the GKE Autopilot AllowlistSynchronizer remove job if operator.gke.autopilot.enabled is true:
  1: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      annotations:
        helm.sh/hook: post-delete
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded,hook-failed
        helm.sh/hook-weight: "-10"
      name: dash0-operator-post-delete
  2: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      annotations:
        helm.sh/hook: post-delete
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded,hook-failed
        helm.sh/hook-weight: "-5"
      name: dash0-operator-post-delete-role
    rules:
      - apiGroups:
          - apiextensions.k8s.io
        resources:
          - customresourcedefinitions
        verbs:
          - get
      - apiGroups:
          - auto.gke.io
        resources:
          - allowlistsynchronizers
        verbs:
          - delete
  3: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRoleBinding
    metadata:
      annotations:
        helm.sh/hook: post-delete
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded,hook-failed
        helm.sh/hook-weight: "-4"
      name: dash0-operator-post-delete-role-binding
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: dash0-operator-post-delete-role
    subjects:
      - kind: ServiceAccount
        name: dash0-operator-post-delete
        namespace: NAMESPACE
  4: |
    apiVersion: batch/v1
    kind: Job
    metadata:
      annotations:
        helm.sh/hook: post-delete
        helm.sh/hook-delete-policy: hook-succeeded
        helm.sh/hook-weight: "0"
      labels:
        app.kubernetes.io/component: remove-allowlist-synchronizer
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: dash0-operator
        app.kubernetes.io/part-of: dash0-operator
        app.kubernetes.io/version: 0.0.0
        dash0.com/enable: "false"
        helm.sh/chart: dash0-operator-0.0.0
      name: dash0-operator-post-delete-remove-allowlist-synchronizer
      namespace: NAMESPACE
    spec:
      backoffLimit: 2
      template:
        metadata:
          labels:
            app.kubernetes.io/component: remove-allowlist-synchronizer
            app.kubernetes.io/instance: post-delete-hook
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: dash0-operator
            helm.sh/chart: dash0-operator-0.0.0
          name: RELEASE-NAME-post-delete-job-remove-allowlist-synchronizer
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: kubernetes.io/os
                        operator: In
                        values:
                          - linux
          automountServiceAccountToken: true
          containers:
            - args:
                - --delete-allowlist-synchronizer
              command:
                - /manager
              env:
                - name: GOMEMLIMIT
                  value: 205MiB
              image: ghcr.io/dash0hq/operator-controller:0.0.0
              imagePullPolicy: null
              name: remove-allowlist-synchronizer-job
              resources:
                limits:
                  cpu: 500m
                  ephemeral-storage: 500Mi
                  memory: 256Mi
                requests:
                  cpu: 50m
                  ephemeral-storage: 500Mi
                  memory: 128Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                seccompProfile:
                  type: RuntimeDefault
          restartPolicy: OnFailure
          securityContext:
            runAsNonRoot: true
          serviceAccountName: dash0-operator-post-delete
