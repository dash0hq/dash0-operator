should install the GKE Autopilot AllowlistSynchronizer ready check if operator.gke.autopilot.enabled is true:
  1: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      annotations:
        helm.sh/hook: pre-install,pre-upgrade
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded,hook-failed
        helm.sh/hook-weight: "-10"
      name: dash0-operator-pre-install
      namespace: NAMESPACE
  2: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      annotations:
        helm.sh/hook: pre-install,pre-upgrade
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded,hook-failed
        helm.sh/hook-weight: "-9"
      name: dash0-operator-pre-install-role
    rules:
      - apiGroups:
          - apiextensions.k8s.io
        resources:
          - customresourcedefinitions
        verbs:
          - get
      - apiGroups:
          - auto.gke.io
        resources:
          - allowlistsynchronizers
        verbs:
          - get
  3: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRoleBinding
    metadata:
      annotations:
        helm.sh/hook: pre-install,pre-upgrade
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded,hook-failed
        helm.sh/hook-weight: "-8"
      name: dash0-operator-pre-install-role-binding
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: dash0-operator-pre-install-role
    subjects:
      - kind: ServiceAccount
        name: dash0-operator-pre-install
        namespace: NAMESPACE
  4: |
    apiVersion: batch/v1
    kind: Job
    metadata:
      annotations:
        helm.sh/hook: pre-install,pre-upgrade
        helm.sh/hook-delete-policy: hook-succeeded
        helm.sh/hook-weight: "-5"
      labels:
        app.kubernetes.io/component: allowlist-synchronizer-ready-check
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: dash0-operator
        app.kubernetes.io/part-of: dash0-operator
        app.kubernetes.io/version: 0.0.0
        dash0.com/enable: "false"
        helm.sh/chart: dash0-operator-0.0.0
      name: dash0-operator-allowlist-synchronizer-ready
      namespace: NAMESPACE
    spec:
      backoffLimit: 2
      template:
        metadata:
          labels:
            app.kubernetes.io/component: allowlist-synchronizer-ready-check
            app.kubernetes.io/instance: pre-install-hook
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: dash0-operator
            cloud.google.com/matching-allowlist: dash0-pre-install-allowlist-synchronizer-ready-check-v1.0.3
            helm.sh/chart: dash0-operator-0.0.0
          name: RELEASE-NAME-pre-install-job-allowlist-synchronizer-ready-check
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: dash0.com/enable
                        operator: NotIn
                        values:
                          - "false"
                      - key: kubernetes.io/os
                        operator: In
                        values:
                          - linux
          automountServiceAccountToken: true
          containers:
            - args:
                - --allowlist-synchronizer-ready-check
                - --dash0-allow-list-version=v1.0.3
              command:
                - /manager
              env:
                - name: GOMEMLIMIT
                  value: 205MiB
              image: ghcr.io/dash0hq/operator-controller:0.0.0
              imagePullPolicy: null
              name: allowlist-synchronizer-ready-check-job
              resources:
                limits:
                  cpu: 500m
                  ephemeral-storage: 500Mi
                  memory: 256Mi
                requests:
                  cpu: 50m
                  ephemeral-storage: 500Mi
                  memory: 128Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                seccompProfile:
                  type: RuntimeDefault
          restartPolicy: OnFailure
          securityContext:
            runAsNonRoot: true
          serviceAccountName: dash0-operator-pre-install
